---
import '../styles/global.css';
import '../styles/animations.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Keri Bakes',
  description = 'Baked with love in Orange County — custom cakes and cupcakes by Keri.',
} = Astro.props;

const navLinks = [
  { label: 'Home',     href: '/'         },
  { label: 'Desserts', href: '/desserts'  },
  { label: 'About',    href: '/about'    },
  { label: 'Order',    href: '/order'    },
];

const currentPath = Astro.url.pathname;
const siteBase = Astro.site?.href.replace(/\/$/, '') ?? 'https://keribakes.com';
const ogImage  = `${siteBase}/images/about/profile-4.jpeg`;
const canonical = `${siteBase}${currentPath}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph (iMessage, Messenger, WhatsApp, Facebook, Slack…) -->
    <meta property="og:type"         content="website" />
    <meta property="og:site_name"    content="Keri Bakes" />
    <meta property="og:url"          content={canonical} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:image"        content={ogImage} />
    <meta property="og:image:type"   content="image/jpeg" />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"    content="Keri Bakes — Baked with Love in Orange County" />
    <meta property="fb:app_id"       content="" />

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- First-load detection (must be inline, not a module) -->
    <script>
      if (!sessionStorage.getItem('keri-first-loaded')) {
        document.documentElement.classList.add('first-load');
        sessionStorage.setItem('keri-first-loaded', '1');
      }
    </script>

    <ClientRouter />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@200;300;400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen flex flex-col bg-cream text-charcoal">

    <!-- Sticky Nav -->
    <header class="sticky top-0 z-50 bg-cream/90 backdrop-blur-sm border-b border-blush/40 animate-on-load">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <!-- Logo -->
        <a
          href="/"
          class="font-display text-2xl tracking-wide text-charcoal hover:text-mauve transition-colors duration-300"
          style="font-family: var(--font-display);"
        >
          Keri Bakes
        </a>

        <!-- Desktop nav links (md = 768px+) -->
        <ul class="hidden md:flex items-center gap-8">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={[
                  'nav-ul-link text-sm font-body tracking-widest uppercase transition-colors duration-200',
                  currentPath === link.href
                    ? 'text-mauve nav-active'
                    : 'text-charcoal/70 hover:text-mauve',
                ].join(' ')}
                style="font-family: var(--font-body); font-weight: 300; letter-spacing: 0.12em;"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Hamburger button (mobile only, below md) -->
        <button
          id="mobile-menu-btn"
          aria-label="Open menu"
          aria-expanded="false"
          type="button"
          class="flex md:hidden flex-col justify-center items-center w-11 h-11 gap-[5px] -mr-1 flex-shrink-0"
        >
          <span class="ham-line"></span>
          <span class="ham-line"></span>
          <span class="ham-line"></span>
        </button>
      </nav>

      <!-- Mobile drawer (slides down inside sticky header) -->
      <div id="mobile-menu" class="mobile-drawer md:hidden">
        <ul>
          {navLinks.filter(l => l.label !== 'Order').map(link => (
            <li>
              <a
                href={link.href}
                class="mobile-nav-link"
                style="font-family: var(--font-body);"
              >
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a
              href="/order"
              class="mobile-nav-order"
              style="font-family: var(--font-body);"
            >
              Order
            </a>
          </li>
        </ul>
      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1" transition:name="page-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-charcoal text-cream/80 mt-auto">
      <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4 text-center md:text-left">
        <span
          class="text-xl tracking-wide"
          style="font-family: var(--font-display); font-weight: 300;"
        >
          Keri Bakes
        </span>

        <a
          href="https://www.instagram.com/keribakesoc/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-cream/60 hover:text-cream transition-colors duration-300"
          style="font-family: var(--font-body); font-weight: 200; letter-spacing: 0.08em;"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="2.5"/>
          </svg>
          @keribakesoc
        </a>

        <p
          class="text-xs text-cream/40"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          &copy; {new Date().getFullYear()} Keri Bakes. All rights reserved.
        </p>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ── Hamburger lines ─────────────────────────────────── */
  .ham-line {
    display: block;
    width: 22px;
    height: 1.5px;
    background: #4A4040;
    border-radius: 1px;
    transform-origin: center;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  #mobile-menu-btn.is-open .ham-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  #mobile-menu-btn.is-open .ham-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #mobile-menu-btn.is-open .ham-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Mobile drawer ───────────────────────────────────── */
  .mobile-drawer {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    background: #FDFAF7;
    box-shadow: 0 4px 16px rgba(74, 64, 64, 0.08);
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }
  .mobile-drawer.is-open {
    max-height: 320px;
    opacity: 1;
  }

  .mobile-nav-link {
    display: block;
    padding: 1rem 1.5rem;
    font-weight: 300;
    font-size: 0.8125rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #4A4040;
    border-bottom: 1px solid rgba(217, 197, 192, 0.5);
    transition: color 0.2s;
  }
  .mobile-nav-link:hover,
  .mobile-nav-link:active {
    color: #A89BAE;
  }

  .mobile-nav-order {
    display: block;
    margin: 0.875rem 1.5rem 1rem;
    padding: 0.75rem 1.5rem;
    font-weight: 300;
    font-size: 0.8125rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-align: center;
    background: #C4B8C8;
    color: #4A4040;
    transition: background 0.2s, color 0.2s;
  }
  .mobile-nav-order:hover,
  .mobile-nav-order:active {
    background: #A89BAE;
    color: #fff;
  }
</style>

<script>
  // Stagger animate-on-load elements on first visit
  document.addEventListener('astro:page-load', () => {
    const items = Array.from(document.querySelectorAll<HTMLElement>('.animate-on-load'));
    items.forEach((el, i) => {
      setTimeout(() => el.classList.add('is-visible'), i * 120);
    });

    // Scroll-triggered reveals
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
  });
</script>

<script>
  // ── Hamburger menu — re-initialised on every page navigation ──
  let menuController: AbortController | null = null;

  document.addEventListener('astro:page-load', () => {
    menuController?.abort();
    menuController = new AbortController();
    const { signal } = menuController;

    const btn  = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu')     as HTMLElement | null;
    if (!btn || !menu) return;

    // Reset to closed on each page load / navigation
    btn.classList.remove('is-open');
    btn.setAttribute('aria-expanded', 'false');
    menu.classList.remove('is-open');

    const openMenu  = () => { btn.classList.add('is-open');    btn.setAttribute('aria-expanded', 'true');  menu.classList.add('is-open');    };
    const closeMenu = () => { btn.classList.remove('is-open'); btn.setAttribute('aria-expanded', 'false'); menu.classList.remove('is-open'); };

    btn.addEventListener('click', () => btn.classList.contains('is-open') ? closeMenu() : openMenu(), { signal });

    // Close when any nav link is tapped
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu, { signal }));

    // Close when tapping outside
    document.addEventListener('click', (e) => {
      if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) closeMenu();
    }, { signal });
  });
</script>
