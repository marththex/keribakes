---
import Layout from '../layouts/Layout.astro';
import CakeGalleryCard from '../components/CakeGalleryCard.astro';
import { GALLERY_CARD_PRICE } from '../lib/pricing';

const products = [
  {
    name: 'Tres Leches Cake',
    description: 'A moist, rich sponge soaked in three milks and topped with fresh whipped cream.',
    sizes: ['6 in (serves 6–8)', '8 in (serves 10–12)', '2 layers · 2 in each · 4 in total'],
    allImages: [
      '/images/gallery/tres-leches-cake/main.jpg',
      '/images/gallery/tres-leches-cake/detail-1.jpg',
      '/images/gallery/tres-leches-cake/detail-2.jpg',
      '/images/gallery/tres-leches-cake/detail-3.jpg',
    ],
  },
  {
    name: 'Tres Leches Cupcakes',
    description: 'All the flavor of our classic tres leches in individual cupcake form. Perfect for smaller gatherings and easy serving.',
    allImages: [
      '/images/gallery/tres-leches-cupcakes/main.jpg',
      '/images/gallery/tres-leches-cupcakes/detail-1.jpg',
      '/images/gallery/tres-leches-cupcakes/detail-2.jpg',
      '/images/gallery/tres-leches-cupcakes/detail-3.jpg',
    ],
  },
  {
    name: 'Cheesecake Cupcakes',
    description: 'Creamy, dense cheesecake in a handheld size. A crowd favorite with a buttery graham cracker base.',
    allImages: [
      '/images/gallery/cheesecake-cupcakes/main.jpg',
      '/images/gallery/cheesecake-cupcakes/detail-1.jpg',
      '/images/gallery/cheesecake-cupcakes/detail-2.jpg',
      '/images/gallery/cheesecake-cupcakes/detail-3.jpg',
    ],
  },
];
---

<Layout
  title="Desserts — Keri Bakes"
  description="Browse custom desserts by Keri Bakes."
>

  <section class="max-w-6xl mx-auto px-6 py-14 md:py-28">

    <!-- Header -->
    <div class="animate-on-load mb-8 md:mb-10 text-center">
      <p
        class="text-xs tracking-[0.2em] uppercase text-mauve mb-4"
        style="font-family: var(--font-body); font-weight: 200;"
      >
        Past Work
      </p>
      <h1
        class="text-charcoal"
        style="font-family: var(--font-display); font-weight: 300; font-size: clamp(2.5rem, 8vw, 3.75rem);"
      >
        Desserts
      </h1>
    </div>

    <!-- Order CTA — centered on mobile, right-aligned on desktop -->
    <div class="flex flex-col items-center md:items-end gap-2 mb-10">
      <a
        href="/order"
        class="btn-lift w-full md:w-auto text-center text-xs tracking-[0.2em] uppercase bg-charcoal text-cream hover:bg-mauve px-8 py-4 md:py-3 transition-colors duration-300"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Order Now
      </a>
      <a
        href="https://www.instagram.com/keribakesoc/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-xs text-mauve/70 hover:text-mauve transition-colors duration-300"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        See more on Instagram →
        <span class="font-normal">@keribakesoc</span>
      </a>
    </div>

    <!-- 3-card grid: 1-col mobile, 2-col tablet, 3-col desktop -->
    <div class="scroll-reveal grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map(product => (
        <CakeGalleryCard
          name={product.name}
          price={GALLERY_CARD_PRICE[product.name]}
          description={product.description}
          allImages={product.allImages}
          sizes={product.sizes}
        />
      ))}
    </div>

    <!-- Bottom copy -->
    <div class="mt-16 text-center">
      <p
        class="text-charcoal/70 mb-6"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        See something you love? Let's create something just for you.
      </p>
      <a
        href="/order"
        class="btn-lift inline-block w-full md:w-auto text-xs tracking-[0.2em] uppercase border border-charcoal/40 text-charcoal/80 hover:border-mauve hover:text-mauve px-8 py-4 md:py-3 transition-all duration-300"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Place an Order
      </a>
    </div>

  </section>

</Layout>
