---
import Layout from '../layouts/Layout.astro';
import ProfileSlideshow from '../components/ProfileSlideshow.astro';
---

<Layout
  title="About — Keri Bakes"
  description="Meet Keri — the baker behind the cakes."
>

  <section class="max-w-5xl mx-auto px-6 py-20 md:py-28">

    <!-- Section label -->
    <p
      class="animate-on-load text-xs tracking-[0.2em] uppercase text-mauve mb-12 text-center"
      style="font-family: var(--font-body); font-weight: 200;"
    >
      The Baker
    </p>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start">

      <!-- Left: photo slideshow -->
      <div class="animate-on-load flex flex-col gap-4">
        <ProfileSlideshow />
        <!-- Accent bar -->
        <div class="h-0.5 w-16 bg-mauve/40 ml-1"></div>
      </div>

      <!-- Right: story text -->
      <div class="animate-on-load flex flex-col gap-8 pt-2">
        <h1
          class="text-5xl md:text-6xl leading-tight text-charcoal"
          style="font-family: var(--font-display); font-weight: 300;"
        >
          Hi, I'm Keri.
        </h1>

        <div
          class="flex flex-col gap-5 text-charcoal/70 leading-relaxed"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          <p>
            Baking has always been my love language. Long before it became a
            business, it was how I showed up for the people I care about —
            a birthday layer cake here, a shower treat box there, and every
            holiday season an embarrassing number of cookies.
          </p>
          <p>
            I'm based in Orange County, and I bake in small batches using
            real butter, seasonal fruit, and flavours that actually taste like
            something. No artificial mixes, no shortcuts.
          </p>
          <p>
            Every cake I make is custom — designed around your celebration,
            your colour palette, and the people you're celebrating with. I
            believe the food at a party should feel as thoughtful as the
            invitation.
          </p>
          <p>
            Let's make your special occasion something deliciously unforgettable.
          </p>
        </div>

        <!-- Accent quote -->
        <blockquote
          class="border-l-2 border-lavender pl-5 mt-2"
        >
          <p
            class="text-2xl italic text-charcoal/50 leading-snug"
            style="font-family: var(--font-display); font-weight: 300;"
          >
            "Every cake tells a story — let's make yours delicious."
          </p>
        </blockquote>

        <!-- CTA -->
        <div class="pt-4 flex flex-col gap-4">
          <a
            href="/order"
            class="btn-lift inline-block text-xs tracking-[0.2em] uppercase border border-charcoal/30 text-charcoal/70 hover:border-mauve hover:text-mauve px-6 py-3 transition-all duration-300"
            style="font-family: var(--font-body); font-weight: 300;"
          >
            Order a Cake
          </a>
          <a
            href="https://www.instagram.com/keribakesoc/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-charcoal/50 hover:text-mauve transition-colors duration-300"
            style="font-family: var(--font-body); font-weight: 300;"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="2.5"/>
            </svg>
            Follow along on Instagram
            <span class="text-mauve/70">@keribakesoc</span>
          </a>
        </div>
      </div>

    </div>
  </section>

</Layout>
