---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Keri Bakes — Custom Celebration Cakes">

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 min-h-[520px]">

      <!-- Left: tagline + CTA -->
      <div class="flex flex-col justify-center gap-6 py-12 pr-8">
        <p
          class="text-xs tracking-[0.2em] uppercase text-mauve"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          Handcrafted in Orange County
        </p>
        <h1
          class="text-5xl md:text-6xl leading-tight text-charcoal"
          style="font-family: var(--font-display); font-weight: 300;"
        >
          Every cake<br />
          <em>tells a story.</em>
        </h1>
        <a
          href="/gallery"
          class="self-start text-xs tracking-[0.2em] uppercase border border-charcoal/40 text-charcoal/80 hover:border-mauve hover:text-mauve px-6 py-3 transition-all duration-300"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          View Gallery
        </a>
      </div>

      <!-- Center: decorative element + callout -->
      <div class="relative flex flex-col items-center justify-center bg-sand/20 py-12 px-6">
        <!-- Decorative circle -->
        <div class="w-48 h-48 rounded-full bg-blush/50 mb-8 flex items-center justify-center shadow-sm">
          <div class="w-36 h-36 rounded-full bg-cream/80 flex items-center justify-center">
            <span
              class="text-4xl text-charcoal/30 select-none"
              aria-hidden="true"
            >
              ✦
            </span>
          </div>
        </div>
        <p
          class="text-xs tracking-[0.18em] uppercase text-mauve mb-2"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          Signature Collection
        </p>
        <h2
          class="text-2xl text-center text-charcoal"
          style="font-family: var(--font-display); font-weight: 400;"
        >
          Custom Creations
        </h2>
        <p
          class="mt-3 text-center text-sm text-charcoal/70 leading-relaxed"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          Each cake is made just for you — your flavours, your vision,
          your moment.
        </p>
      </div>

      <!-- Right: gradient + Order CTA -->
      <div
        class="flex flex-col items-center justify-center py-12 px-8 text-center"
        style="background: linear-gradient(160deg, #C4B8C8 0%, #D9C5C0 100%);"
      >
        <p
          class="text-xs tracking-[0.2em] uppercase text-charcoal/70 mb-4"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          Ready to celebrate?
        </p>
        <h2
          class="text-3xl text-charcoal mb-6 leading-snug"
          style="font-family: var(--font-display); font-weight: 300;"
        >
          Let's bake something beautiful
        </h2>
        <a
          href="/order"
          class="bg-charcoal text-cream text-xs tracking-[0.2em] uppercase px-8 py-3 hover:bg-mauve transition-all duration-300"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          Order Now
        </a>
        <p
          class="mt-4 text-xs text-charcoal/60"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          Minimum 7 days notice required
        </p>
      </div>

    </div>
  </section>

  <!-- ── WARM PARAGRAPH ─────────────────────────────────────── -->
  <section class="border-t border-blush/40 bg-cream">
    <div class="max-w-2xl mx-auto px-6 py-20 md:py-24 text-center flex flex-col items-center gap-8">
      <p
        class="text-2xl md:text-3xl text-charcoal leading-relaxed"
        style="font-family: var(--font-display); font-weight: 300; font-style: italic;"
      >
        Baking isn't just something I do — it's how I show love. Every cake
        that leaves my kitchen carries a piece of my heart, made from scratch
        with intention, warmth, and the quiet joy of creating something
        beautiful for someone else's special day.
      </p>
      <a
        href="https://www.instagram.com/keribakesoc/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-charcoal/40 hover:text-mauve transition-colors duration-300"
        style="font-family: var(--font-body); font-weight: 300; letter-spacing: 0.06em;"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="2.5"/>
        </svg>
        @keribakesoc
      </a>
    </div>
  </section>

</Layout>
