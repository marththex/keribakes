---
import Layout from '../layouts/Layout.astro';

const categories = [
  { name: 'Birthday',     occasion: 'Celebration',   bg: 'bg-blush/40'    },
  { name: 'Baby Shower',  occasion: 'New Arrival',    bg: 'bg-lavender/40' },
  { name: 'Graduation',   occasion: 'Milestone',      bg: 'bg-sand/40'     },
  { name: 'Bespoke',      occasion: 'Any Occasion',   bg: 'bg-mauve/20'    },
];
---

<Layout title="Keri Bakes — Custom Celebration Cakes">

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 min-h-[520px]">

      <!-- Left: tagline + CTA -->
      <div class="flex flex-col justify-center gap-6 py-12 pr-8">
        <p
          class="text-xs tracking-[0.2em] uppercase text-mauve"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          Handcrafted in Orange County
        </p>
        <h1
          class="text-5xl md:text-6xl leading-tight text-charcoal"
          style="font-family: var(--font-display); font-weight: 300;"
        >
          Every cake<br />
          <em>tells a story.</em>
        </h1>
        <p
          class="text-charcoal/60 leading-relaxed"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          Celebration cakes made with seasonal ingredients, real butter,
          and a whole lot of love.
        </p>
        <a
          href="/gallery"
          class="self-start text-xs tracking-[0.2em] uppercase border border-charcoal/30 text-charcoal/70 hover:border-mauve hover:text-mauve px-6 py-3 transition-all duration-300"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          View Gallery
        </a>
      </div>

      <!-- Center: decorative element + callout -->
      <div class="relative flex flex-col items-center justify-center bg-sand/20 py-12 px-6">
        <!-- Decorative circle -->
        <div class="w-48 h-48 rounded-full bg-blush/50 mb-8 flex items-center justify-center shadow-sm">
          <div class="w-36 h-36 rounded-full bg-cream/80 flex items-center justify-center">
            <span
              class="text-4xl text-charcoal/30 select-none"
              aria-hidden="true"
            >
              ✦
            </span>
          </div>
        </div>
        <p
          class="text-xs tracking-[0.18em] uppercase text-charcoal/40 mb-2"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          Signature Collection
        </p>
        <h2
          class="text-2xl text-center text-charcoal"
          style="font-family: var(--font-display); font-weight: 400;"
        >
          Custom Creations
        </h2>
        <p
          class="mt-3 text-center text-sm text-charcoal/50 leading-relaxed"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          Each cake is designed around you — your colours, your flavours,
          your moment.
        </p>
      </div>

      <!-- Right: gradient + Order CTA -->
      <div
        class="flex flex-col items-center justify-center py-12 px-8 text-center"
        style="background: linear-gradient(160deg, #C4B8C8 0%, #D9C5C0 100%);"
      >
        <p
          class="text-xs tracking-[0.2em] uppercase text-cream/70 mb-4"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          Ready to celebrate?
        </p>
        <h2
          class="text-3xl text-cream mb-6 leading-snug"
          style="font-family: var(--font-display); font-weight: 300;"
        >
          Let's bake something beautiful
        </h2>
        <a
          href="/order"
          class="bg-cream text-charcoal text-xs tracking-[0.2em] uppercase px-8 py-3 hover:bg-charcoal hover:text-cream transition-all duration-300"
          style="font-family: var(--font-body); font-weight: 300;"
        >
          Order Now
        </a>
        <p
          class="mt-4 text-xs text-cream/50"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          Minimum 7 days notice required
        </p>
      </div>

    </div>
  </section>

  <!-- ── CATEGORY STRIP ─────────────────────────────────── -->
  <section class="border-t border-blush/40 bg-cream">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <p
        class="text-xs tracking-[0.2em] uppercase text-mauve mb-10 text-center"
        style="font-family: var(--font-body); font-weight: 200;"
      >
        What I Make
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {categories.map(cat => (
          <a
            href="/gallery"
            class={`group ${cat.bg} p-8 flex flex-col gap-3 hover:shadow-md transition-shadow duration-300`}
          >
            <span
              class="text-xl text-charcoal group-hover:text-mauve transition-colors duration-300"
              style="font-family: var(--font-display); font-weight: 400;"
            >
              {cat.name}
            </span>
            <span
              class="text-xs tracking-[0.14em] uppercase text-charcoal/40"
              style="font-family: var(--font-body); font-weight: 200;"
            >
              {cat.occasion}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>
