---
import Layout from '../layouts/Layout.astro';
import { CAKE_OPTIONS, TIME_SLOTS, REFERRAL_OPTIONS } from '../lib/orderSchema';
import { PRICING } from '../lib/pricing';

// Minimum date (server-side, for setting the <input min> attribute)
const minDate = new Date();
minDate.setDate(minDate.getDate() + 7);
const minDateStr = minDate.toISOString().split('T')[0];
---

<Layout
  title="Order — Keri Bakes"
  description="Place a custom cake inquiry with Keri Bakes."
>
  <section class="max-w-2xl mx-auto px-6 py-20 md:py-28">

    <!-- Header -->
    <div class="animate-on-load mb-12 text-center">
      <p
        class="text-xs tracking-[0.2em] uppercase text-mauve mb-4"
        style="font-family: var(--font-body); font-weight: 200;"
      >
        Let's get started
      </p>
      <h1
        class="text-5xl md:text-6xl text-charcoal"
        style="font-family: var(--font-display); font-weight: 300;"
      >
        Place an Inquiry
      </h1>
      <p
        class="mt-4 text-charcoal/70 leading-relaxed"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Fill out the form below and I'll be in touch within 24–48 hours
        to confirm your date and discuss the details.
      </p>
    </div>

    <!-- ── FORM ──────────────────────────────────────────────── -->
    <form
      id="order-form"
      novalidate
      class="flex flex-col gap-8"
    >

      <!-- Contact details -->
      <fieldset class="flex flex-col gap-5">
        <legend
          class="text-xs tracking-[0.18em] uppercase text-mauve mb-1"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          Your Details
        </legend>

        <div class="flex flex-col gap-1">
          <label for="name" class="form-label">Full Name *</label>
          <input id="name" name="name" type="text" autocomplete="name"
            class="form-input" placeholder="Jane Smith" />
          <p class="form-error hidden" data-error="name"></p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="flex flex-col gap-1">
            <label for="email" class="form-label">Email *</label>
            <input id="email" name="email" type="email" autocomplete="email"
              class="form-input" placeholder="jane@example.com" />
            <p class="form-error hidden" data-error="email"></p>
          </div>
          <div class="flex flex-col gap-1">
            <label for="phone" class="form-label">Phone *</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel"
              class="form-input" placeholder="(714) 555-0100" />
            <p class="form-error hidden" data-error="phone"></p>
          </div>
        </div>
      </fieldset>

      <!-- Cake selection -->
      <fieldset class="flex flex-col gap-5">
        <legend
          class="text-xs tracking-[0.18em] uppercase text-mauve mb-1"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          Dessert Selection
        </legend>

        <div class="flex flex-col gap-1">
          <label for="cakeSelection" class="form-label">Select Your Dessert *</label>
          <select id="cakeSelection" name="cakeSelection" class="form-input">
            <option value="">Choose a dessert…</option>
            {CAKE_OPTIONS.map(cake => <option value={cake}>{cake} — {PRICING[cake]}</option>)}
          </select>
          <p class="form-error hidden" data-error="cakeSelection"></p>
        </div>

        <!-- Pricing note -->
        <p
          class="text-charcoal/60 leading-relaxed"
          style="font-family: var(--font-body); font-weight: 300; font-size: 0.8125rem; font-style: italic;"
        >
          Final price is determined by additions such as fruit toppings, organic
          ingredients, specific decorations, candles, and more.
        </p>

        <div class="flex flex-col gap-1">
          <label for="addOns" class="form-label">Add-ons &amp; Special Requests</label>
          <textarea id="addOns" name="addOns" rows={3}
            class="form-input resize-none"
            placeholder="e.g. fresh fruit, candles, organic ingredients, specific decorations..."
          ></textarea>
        </div>
      </fieldset>

      <!-- Date + Fulfillment -->
      <fieldset class="flex flex-col gap-5">
        <legend
          class="text-xs tracking-[0.18em] uppercase text-mauve mb-1"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          Date &amp; Fulfillment
        </legend>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="flex flex-col gap-1">
            <label for="requestedDate" class="form-label">
              Requested Date *
              <span
                class="ml-2 text-charcoal/60 normal-case tracking-normal"
                style="font-size: 11px;"
              >
                (min. 7 days from today)
              </span>
            </label>
            <input
              id="requestedDate"
              name="requestedDate"
              type="date"
              min={minDateStr}
              class="form-input"
            />
            <p class="form-error hidden" data-error="requestedDate"></p>
          </div>

          <div class="flex flex-col gap-1">
            <label for="preferredTime" class="form-label">Preferred Time *</label>
            <select id="preferredTime" name="preferredTime" class="form-input">
              <option value="">Select a time</option>
              {TIME_SLOTS.map(t => <option value={t}>{t}</option>)}
            </select>
            <p class="form-error hidden" data-error="preferredTime"></p>
          </div>
        </div>

        <div class="flex gap-6">
          <label class="fulfillment-option">
            <input type="radio" name="fulfillment" value="pickup" checked
              class="sr-only peer" />
            <span class="fulfillment-pill peer-checked:fulfillment-pill-active">
              Pickup
            </span>
          </label>
          <label class="fulfillment-option">
            <input type="radio" name="fulfillment" value="delivery"
              class="sr-only peer" />
            <span class="fulfillment-pill peer-checked:fulfillment-pill-active">
              Delivery
            </span>
          </label>
        </div>

        <!-- Delivery fields — shown/hidden by JS -->
        <div id="delivery-fields" class="hidden flex flex-col gap-5">
          <div class="flex flex-col gap-1">
            <label for="county" class="form-label">Delivery County *</label>
            <select id="county" name="county" class="form-input">
              <option value="">Select county…</option>
              <option value="Orange County">Orange County</option>
              <option value="Los Angeles County">Los Angeles County</option>
            </select>
            <p class="form-error hidden" data-error="county"></p>
          </div>
          <div class="flex flex-col gap-1">
            <label for="street" class="form-label">Street Address *</label>
            <input id="street" name="street" type="text"
              autocomplete="address-line1"
              class="form-input"
              placeholder="123 Blossom Ave" />
            <p class="form-error hidden" data-error="street"></p>
          </div>
          <div class="grid grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="unit" class="form-label">Apt / Suite</label>
              <input id="unit" name="unit" type="text"
                autocomplete="address-line2"
                class="form-input"
                placeholder="Apt 4B (optional)" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="zip" class="form-label">ZIP Code *</label>
              <input id="zip" name="zip" type="text"
                autocomplete="postal-code"
                inputmode="numeric"
                maxlength="5"
                class="form-input"
                placeholder="92618" />
              <p class="form-error hidden" data-error="zip"></p>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <label for="city" class="form-label">City *</label>
            <input id="city" name="city" type="text"
              autocomplete="address-level2"
              class="form-input"
              placeholder="Irvine" />
            <p class="form-error hidden" data-error="city"></p>
          </div>
        </div>

        <!-- Sweetness / add-ons note -->
        <p
          class="text-charcoal/60 leading-relaxed"
          style="font-family: var(--font-body); font-weight: 300; font-size: 0.8125rem; font-style: italic;"
        >
          Please note: sweetness cannot be adjusted. Add-ons such as fruit,
          candles, and decorations are welcome.
        </p>
      </fieldset>

      <!-- Optional referral -->
      <fieldset class="flex flex-col gap-2">
        <legend
          class="text-xs tracking-[0.18em] uppercase text-mauve mb-1"
          style="font-family: var(--font-body); font-weight: 200;"
        >
          Optional
        </legend>
        <label for="referral" class="form-label">How did you hear about me?</label>
        <select id="referral" name="referral" class="form-input">
          <option value="">Select an option…</option>
          {REFERRAL_OPTIONS.map(opt => <option value={opt}>{opt}</option>)}
        </select>
        <div id="referral-other-wrapper" class="hidden flex flex-col gap-1 mt-1">
          <input
            id="referralOther"
            name="referralOther"
            type="text"
            class="form-input"
            placeholder="Please tell us how you heard about us"
          />
          <p class="form-error hidden" data-error="referralOther"></p>
        </div>
        <div id="referral-friend-wrapper" class="hidden flex flex-col gap-1 mt-1">
          <input
            id="referralFriend"
            name="referralFriend"
            type="text"
            class="form-input"
            placeholder="Friend's name"
          />
          <p class="form-error hidden" data-error="referralFriend"></p>
        </div>
      </fieldset>

      <!-- Global server error -->
      <p
        id="server-error"
        class="hidden text-sm text-red-600 bg-red-50 border border-red-200 px-4 py-3"
        style="font-family: var(--font-body); font-weight: 300;"
        role="alert"
      ></p>

      <!-- Submit -->
      <button
        type="submit"
        id="submit-btn"
        class="btn-lift self-start text-xs tracking-[0.2em] uppercase bg-charcoal text-cream px-10 py-4 hover:bg-mauve transition-colors duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Send Inquiry
      </button>

    </form>

    <!-- ── SUCCESS STATE ──────────────────────────────────────── -->
    <div
      id="success-msg"
      class="hidden flex flex-col items-center text-center gap-6 py-16"
      role="alert"
    >
      <div class="w-16 h-16 rounded-full bg-lavender/40 flex items-center justify-center text-2xl">
        ✦
      </div>
      <h2
        class="text-4xl text-charcoal"
        style="font-family: var(--font-display); font-weight: 300;"
      >
        Inquiry received!
      </h2>
      <p
        class="text-charcoal/70 max-w-sm leading-relaxed"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Thank you — I'll be in touch within 24–48 hours to discuss the details
        and confirm your date. Keep an eye on your inbox (and spam, just in case).
      </p>
      <a
        href="/desserts"
        class="text-xs tracking-[0.2em] uppercase border border-charcoal/30 text-charcoal/70 hover:border-mauve hover:text-mauve px-6 py-3 transition-all duration-300"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Browse the Gallery
      </a>
    </div>

  </section>
</Layout>

<!-- ── Inline styles for reusable form classes ────────────────── -->
<style>
  .form-label {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4A4040;
    opacity: 0.8;
  }

  .form-input {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.9375rem;
    color: #4A4040;
    background: #fff;
    border: 1px solid #D9C5C0;
    padding: 0.75rem 1rem;
    width: 100%;
    outline: none;
    transition: border-color 0.2s;
    appearance: none;
    -webkit-appearance: none;
  }

  .form-input:focus {
    border-color: #A89BAE;
  }

  .form-input.input-error {
    border-color: #c0392b;
  }

  .form-error {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.75rem;
    color: #c0392b;
    margin-top: 2px;
  }

  .fulfillment-option {
    cursor: pointer;
  }

  .fulfillment-pill {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid #D9C5C0;
    color: #4A4040;
    opacity: 0.7;
    padding: 0.5rem 1.5rem;
    transition: all 0.2s;
    cursor: pointer;
  }

  .fulfillment-pill:hover {
    border-color: #A89BAE;
    opacity: 1;
  }

  .fulfillment-pill-active,
  .peer:checked ~ .fulfillment-pill {
    border-color: #A89BAE;
    background-color: #A89BAE;
    color: #fff;
    opacity: 1;
  }
</style>

<!-- ── Client-side validation & submission ────────────────────── -->
<script>
  import { z } from 'zod';
  import { orderSchema } from '../lib/orderSchema';

  const form        = document.getElementById('order-form')      as HTMLFormElement;
  const submitBtn   = document.getElementById('submit-btn')      as HTMLButtonElement;
  const successMsg  = document.getElementById('success-msg')     as HTMLElement;
  const serverErr   = document.getElementById('server-error')    as HTMLElement;
  const delivFields = document.getElementById('delivery-fields') as HTMLElement;

  // ── Delivery toggle ─────────────────────────────────────────
  const radios = form.querySelectorAll<HTMLInputElement>('input[name="fulfillment"]');
  radios.forEach(r => r.addEventListener('change', () => {
    const isDelivery = (form.elements.namedItem('fulfillment') as RadioNodeList).value === 'delivery';
    delivFields.classList.toggle('hidden', !isDelivery);
  }));

  // ── Referral "Other" toggle ──────────────────────────────────
  const referralSelect        = form.querySelector<HTMLSelectElement>('#referral');
  const referralOtherWrapper  = document.getElementById('referral-other-wrapper')  as HTMLElement;
  const referralFriendWrapper = document.getElementById('referral-friend-wrapper') as HTMLElement;
  referralSelect?.addEventListener('change', () => {
    referralOtherWrapper.classList.toggle('hidden',  referralSelect.value !== 'Other');
    referralFriendWrapper.classList.toggle('hidden', referralSelect.value !== 'Referred by a friend');
  });

  // ── Helpers ─────────────────────────────────────────────────
  function showError(field: string, msg: string) {
    const el    = form.querySelector<HTMLElement>(`[data-error="${field}"]`);
    const input = form.querySelector<HTMLElement>(`#${field}`) ??
                  form.querySelector<HTMLElement>(`[name="${field}"]`);
    if (el)    { el.textContent = msg; el.classList.remove('hidden'); }
    if (input) input.classList.add('input-error');
  }

  function clearErrors() {
    form.querySelectorAll('.form-error').forEach(el => {
      el.classList.add('hidden');
      (el as HTMLElement).textContent = '';
    });
    form.querySelectorAll('.input-error').forEach(el => el.classList.remove('input-error'));
    serverErr.classList.add('hidden');
    serverErr.textContent = '';
  }

  function collectData(): Record<string, unknown> {
    const fd = new FormData(form);
    return {
      name:           fd.get('name'),
      email:          fd.get('email'),
      phone:          fd.get('phone'),
      cakeSelection:  fd.get('cakeSelection'),
      addOns:         fd.get('addOns')          ?? undefined,
      preferredTime:  fd.get('preferredTime'),
      requestedDate:  fd.get('requestedDate'),
      fulfillment:    fd.get('fulfillment'),
      county:         fd.get('county')          ?? undefined,
      street:         fd.get('street')          ?? undefined,
      unit:           fd.get('unit')            ?? undefined,
      city:           fd.get('city')            ?? undefined,
      zip:            fd.get('zip')             ?? undefined,
      referral:       fd.get('referral')        ?? undefined,
      referralOther:  fd.get('referralOther')   ?? undefined,
      referralFriend: fd.get('referralFriend')  ?? undefined,
    };
  }

  // ── Submit ───────────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();

    const raw = collectData();

    // Client-side Zod validation
    const result = orderSchema.safeParse(raw);
    if (!result.success) {
      const flat = z.flattenError(result.error).fieldErrors;
      let firstField: string | null = null;
      for (const [field, msgs] of Object.entries(flat)) {
        if (msgs && msgs.length > 0) {
          showError(field, msgs[0]);
          if (!firstField) firstField = field;
        }
      }
      if (firstField) {
        const el = form.querySelector<HTMLElement>(`#${firstField}`);
        el?.focus();
        el?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return;
    }

    // POST to API
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const resp = await fetch('/api/order', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(result.data),
      });

      const json = await resp.json() as {
        success: boolean;
        error?: string;
        fieldErrors?: Record<string, string[]>;
      };

      if (json.success) {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else if (json.fieldErrors) {
        for (const [field, msgs] of Object.entries(json.fieldErrors)) {
          if (msgs && msgs.length > 0) showError(field, msgs[0]);
        }
      } else {
        serverErr.textContent = json.error ?? 'Something went wrong. Please try again.';
        serverErr.classList.remove('hidden');
      }
    } catch {
      serverErr.textContent = 'Network error — please check your connection and try again.';
      serverErr.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Inquiry';
    }
  });
</script>
