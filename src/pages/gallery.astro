---
import Layout from '../layouts/Layout.astro';

interface GalleryItem {
  name: string;
  occasion: string;
  bg: string;
}

const items: GalleryItem[] = [
  { name: 'Strawberry Chiffon',    occasion: 'Birthday',       bg: '#D9C5C0' },
  { name: 'Lavender Honey',        occasion: 'Baby Shower',    bg: '#C4B8C8' },
  { name: 'Brown Butter Peach',    occasion: 'Birthday',       bg: '#DFC5AE' },
  { name: 'Vanilla Rose',          occasion: 'Graduation',     bg: '#E8D8D2' },
  { name: 'Earl Grey Lemon',       occasion: 'Bespoke',        bg: '#D0C8D8' },
  { name: 'Salted Caramel Layer',  occasion: 'Birthday',       bg: '#E2D0BA' },
  { name: 'Matcha White Choc',     occasion: 'Baby Shower',    bg: '#C8D4C0' },
  { name: 'Raspberry Almond',      occasion: 'Graduation',     bg: '#D8C0C8' },
  { name: 'Coconut Pandan',        occasion: 'Bespoke',        bg: '#C8D8C8' },
];

const occasionColors: Record<string, string> = {
  Birthday:    '#A89BAE',
  'Baby Shower': '#C4B8C8',
  Graduation:  '#DFC5AE',
  Bespoke:     '#D9C5C0',
};
---

<Layout
  title="Gallery — Keri Bakes"
  description="Browse past custom cakes by Keri Bakes."
>

  <section class="max-w-6xl mx-auto px-6 py-20 md:py-28">

    <!-- Header -->
    <div class="mb-14 text-center">
      <p
        class="text-xs tracking-[0.2em] uppercase text-mauve mb-4"
        style="font-family: var(--font-body); font-weight: 200;"
      >
        Past Work
      </p>
      <h1
        class="text-5xl md:text-6xl text-charcoal"
        style="font-family: var(--font-display); font-weight: 300;"
      >
        The Gallery
      </h1>
      <p
        class="mt-4 text-charcoal/50 max-w-sm mx-auto leading-relaxed"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Real photos coming soon. Each placeholder represents a cake category
        I love to make.
      </p>
    </div>

    <!-- Responsive grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map(item => (
        <article class="group flex flex-col overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">

          <!-- Placeholder image area -->
          <div
            class="w-full aspect-square flex items-center justify-center"
            style={`background-color: ${item.bg};`}
            aria-label={`${item.name} — photo coming soon`}
          >
            <span
              class="text-white/30 text-4xl select-none"
              aria-hidden="true"
            >
              ✦
            </span>
          </div>

          <!-- Card label -->
          <div class="bg-cream px-5 py-4 flex items-start justify-between gap-2">
            <h2
              class="text-base text-charcoal group-hover:text-mauve transition-colors duration-300"
              style="font-family: var(--font-display); font-weight: 400;"
            >
              {item.name}
            </h2>
            <span
              class="text-xs tracking-[0.12em] uppercase shrink-0 mt-0.5"
              style={`font-family: var(--font-body); font-weight: 200; color: ${occasionColors[item.occasion] ?? '#A89BAE'};`}
            >
              {item.occasion}
            </span>
          </div>

        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 text-center">
      <p
        class="text-charcoal/50 mb-6"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        See something you love? Let's create something just for you.
      </p>
      <a
        href="/order"
        class="inline-block text-xs tracking-[0.2em] uppercase border border-charcoal/30 text-charcoal/70 hover:border-mauve hover:text-mauve px-8 py-3 transition-all duration-300"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Place an Order
      </a>
    </div>

  </section>

</Layout>
