---
import Layout from '../layouts/Layout.astro';

interface CakeProduct {
  name: string;
  slug: string;
  price: string;
  description: string;
  mainImage: string;
  detailImages: string[];
}

const products: CakeProduct[] = [
  {
    name: 'Tres Leches Cake',
    slug: 'tres-leches-cake',
    price: 'From $65',
    description: 'A moist, rich sponge soaked in three milks and topped with fresh whipped cream. Light, indulgent, and made from scratch.',
    mainImage: '/images/gallery/tres-leches-cake/main.jpg',
    detailImages: [
      '/images/gallery/tres-leches-cake/detail-1.jpg',
      '/images/gallery/tres-leches-cake/detail-2.jpg',
      '/images/gallery/tres-leches-cake/detail-3.jpg',
    ],
  },
  {
    name: 'Tres Leches Cupcakes',
    slug: 'tres-leches-cupcakes',
    price: 'From $48 / dozen',
    description: 'All the flavor of our classic tres leches in individual cupcake form. Perfect for smaller gatherings and easy serving.',
    mainImage: '/images/gallery/tres-leches-cupcakes/main.jpg',
    detailImages: [
      '/images/gallery/tres-leches-cupcakes/detail-1.jpg',
      '/images/gallery/tres-leches-cupcakes/detail-2.jpg',
      '/images/gallery/tres-leches-cupcakes/detail-3.jpg',
    ],
  },
  {
    name: 'Cheesecake Cupcakes',
    slug: 'cheesecake-cupcakes',
    price: 'From $48 / dozen',
    description: 'Creamy, dense cheesecake in a handheld size. A crowd favorite with a buttery graham cracker base.',
    mainImage: '/images/gallery/cheesecake-cupcakes/main.jpg',
    detailImages: [
      '/images/gallery/cheesecake-cupcakes/detail-1.jpg',
      '/images/gallery/cheesecake-cupcakes/detail-2.jpg',
      '/images/gallery/cheesecake-cupcakes/detail-3.jpg',
    ],
  },
];

// Flatten into one ordered list: main first, then details
interface GalleryCard {
  src: string;
  alt: string;
  name: string;
  price: string;
  description: string;
  isMain: boolean;
}

const cards: GalleryCard[] = products.flatMap(p => [
  {
    src: p.mainImage,
    alt: p.name,
    name: p.name,
    price: p.price,
    description: p.description,
    isMain: true,
  },
  ...p.detailImages.map((src, i) => ({
    src,
    alt: `${p.name} — detail ${i + 1}`,
    name: p.name,
    price: p.price,
    description: p.description,
    isMain: false,
  })),
]);
---

<Layout
  title="Gallery — Keri Bakes"
  description="Browse custom cakes by Keri Bakes."
>

  <section class="max-w-6xl mx-auto px-6 py-20 md:py-28">

    <!-- Header -->
    <div class="mb-10 text-center">
      <p
        class="text-xs tracking-[0.2em] uppercase text-mauve mb-4"
        style="font-family: var(--font-body); font-weight: 200;"
      >
        Past Work
      </p>
      <h1
        class="text-5xl md:text-6xl text-charcoal"
        style="font-family: var(--font-display); font-weight: 300;"
      >
        The Gallery
      </h1>
    </div>

    <!-- Order CTA — top, right-aligned -->
    <div class="flex justify-end mb-10">
      <a
        href="/order"
        class="text-xs tracking-[0.2em] uppercase bg-charcoal text-cream hover:bg-mauve px-8 py-3 transition-colors duration-300"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Order Now
      </a>
    </div>

    <!-- Responsive grid — 12 cards total (main + 3 details × 3 products) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map(card => (
        <article class="group flex flex-col overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">

          <img
            src={card.src}
            alt={card.alt}
            class="w-full aspect-square object-cover"
            loading="lazy"
            decoding="async"
          />

          {card.isMain && (
            <div class="bg-cream px-5 py-5 flex flex-col gap-2">
              <div class="flex items-baseline justify-between gap-2">
                <h2
                  class="text-base text-charcoal group-hover:text-mauve transition-colors duration-300"
                  style="font-family: var(--font-display); font-weight: 400;"
                >
                  {card.name}
                </h2>
                <span
                  class="text-xs tracking-[0.08em] shrink-0 text-mauve"
                  style="font-family: var(--font-body); font-weight: 300;"
                >
                  {card.price}
                </span>
              </div>
              <p
                class="text-charcoal/70 leading-relaxed"
                style="font-family: var(--font-body); font-weight: 300; font-size: 0.8125rem;"
              >
                {card.description}
              </p>
            </div>
          )}

        </article>
      ))}
    </div>

    <!-- Bottom copy -->
    <div class="mt-16 text-center">
      <p
        class="text-charcoal/70 mb-6"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        See something you love? Let's create something just for you.
      </p>
      <a
        href="/order"
        class="inline-block text-xs tracking-[0.2em] uppercase border border-charcoal/40 text-charcoal/80 hover:border-mauve hover:text-mauve px-8 py-3 transition-all duration-300"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        Place an Order
      </a>
    </div>

  </section>

</Layout>
