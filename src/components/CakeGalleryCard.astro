---
interface Props {
  name: string;
  price: string;
  description: string;
  allImages: string[];
}

const { name, price, description, allImages } = Astro.props;
---

<article class="gallery-card flex flex-col overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">

  <!-- Image carousel -->
  <div class="relative" data-carousel>
    <div class="relative aspect-square overflow-hidden img-wrapper">
      {allImages.map((src, i) => (
        <img
          src={src}
          alt={`${name} — photo ${i + 1}`}
          class={`gallery-img-filter absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
          data-carousel-img={i}
          loading="lazy"
          decoding="async"
        />
      ))}
    </div>

    <!-- Left arrow -->
    <button
      class="carousel-prev absolute left-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 rounded-full bg-white/60 hover:bg-white/85 flex items-center justify-center transition-colors duration-200"
      aria-label="Previous photo"
      type="button"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="#4A4040" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9,2 4,7 9,12" />
      </svg>
    </button>

    <!-- Right arrow -->
    <button
      class="carousel-next absolute right-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 rounded-full bg-white/60 hover:bg-white/85 flex items-center justify-center transition-colors duration-200"
      aria-label="Next photo"
      type="button"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="#4A4040" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="5,2 10,7 5,12" />
      </svg>
    </button>
  </div>

  <!-- Dot indicators -->
  <div class="flex justify-center gap-2 py-3 bg-cream">
    {allImages.map((_, i) => (
      <button
        class={`w-2 h-2 rounded-full border transition-all duration-300 ${i === 0 ? 'bg-mauve border-mauve' : 'bg-transparent border-mauve/50'}`}
        data-dot={i}
        aria-label={`Go to photo ${i + 1}`}
        type="button"
      />
    ))}
  </div>

  <!-- Card info -->
  <div class="bg-cream px-5 pb-5 flex flex-col gap-2">
    <div class="flex items-baseline justify-between gap-2">
      <h2
        class="text-base text-charcoal"
        style="font-family: var(--font-display); font-weight: 400;"
      >
        {name}
      </h2>
      <span
        class="text-xs tracking-[0.08em] shrink-0 text-mauve"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        {price}
      </span>
    </div>
    <p
      class="text-charcoal/70 leading-relaxed"
      style="font-family: var(--font-body); font-weight: 300; font-size: 0.8125rem;"
    >
      {description}
    </p>
  </div>
</article>

<style>
  .gallery-img-filter {
    filter: brightness(1.05) contrast(1.08) saturate(1.1);
  }

  .img-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 245, 235, 0.08);
    mix-blend-mode: multiply;
    pointer-events: none;
    z-index: 1;
  }
</style>

<script>
  function initCarousel(card: Element): void {
    const imgs  = card.querySelectorAll<HTMLElement>('[data-carousel-img]');
    const dots  = card.querySelectorAll<HTMLElement>('[data-dot]');
    const total = imgs.length;
    if (total === 0) return;
    let current = 0;

    function goTo(index: number): void {
      imgs[current].classList.remove('opacity-100');
      imgs[current].classList.add('opacity-0');
      dots[current].classList.remove('bg-mauve', 'border-mauve');
      dots[current].classList.add('bg-transparent', 'border-mauve/50');

      current = ((index % total) + total) % total;

      imgs[current].classList.remove('opacity-0');
      imgs[current].classList.add('opacity-100');
      dots[current].classList.remove('bg-transparent', 'border-mauve/50');
      dots[current].classList.add('bg-mauve', 'border-mauve');
    }

    card.querySelector('.carousel-prev')?.addEventListener('click', () => goTo(current - 1));
    card.querySelector('.carousel-next')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // Touch swipe support
    const carousel = card.querySelector<HTMLElement>('[data-carousel]');
    if (!carousel) return;
    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    carousel.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    }, { passive: true });
  }

  document.querySelectorAll('.gallery-card').forEach(initCarousel);
</script>
