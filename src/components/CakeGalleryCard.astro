---
interface Props {
  name: string;
  price: string;
  description: string;
  mainImage: string;
  allImages: string[];
}

const { name, price, description, mainImage, allImages } = Astro.props;
---

<article
  class="gallery-card group cursor-pointer flex flex-col overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300"
  data-images={JSON.stringify(allImages)}
>
  <div class="overflow-hidden">
    <img
      src={mainImage}
      alt={name}
      class="w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Dot indicators -->
  <div class="flex justify-center gap-2 py-3 bg-cream">
    {allImages.map((_, i) => (
      <span
        class={`w-1.5 h-1.5 rounded-full ${i === 0 ? 'bg-mauve' : 'bg-blush'}`}
      />
    ))}
  </div>

  <!-- Card info -->
  <div class="bg-cream px-5 pb-5 flex flex-col gap-2">
    <div class="flex items-baseline justify-between gap-2">
      <h2
        class="text-base text-charcoal group-hover:text-mauve transition-colors duration-300"
        style="font-family: var(--font-display); font-weight: 400;"
      >
        {name}
      </h2>
      <span
        class="text-xs tracking-[0.08em] shrink-0 text-mauve"
        style="font-family: var(--font-body); font-weight: 300;"
      >
        {price}
      </span>
    </div>
    <p
      class="text-charcoal/70 leading-relaxed"
      style="font-family: var(--font-body); font-weight: 300; font-size: 0.8125rem;"
    >
      {description}
    </p>
  </div>
</article>

<script>
  import PhotoSwipe from 'photoswipe';
  import 'photoswipe/style.css';

  function openGallery(images: string[]) {
    const pswp = new PhotoSwipe({
      dataSource: images.map(src => ({ src, width: 1200, height: 1200 })),
      index: 0,
      bgOpacity: 0.92,
      clickToCloseNonZoomable: false,
    });

    pswp.on('contentLoad', (e) => {
      const { content } = e;
      if (content.type !== 'image') return;
      e.preventDefault();
      const img = new Image();
      img.onload = () => {
        content.data.width = img.naturalWidth;
        content.data.height = img.naturalHeight;
        content.element = img;
        content.finish();
      };
      img.onerror = () => content.error();
      img.src = String(content.data.src);
    });

    pswp.init();
  }

  document.querySelectorAll<HTMLElement>('.gallery-card').forEach(card => {
    card.addEventListener('click', () => {
      const images = JSON.parse(card.dataset.images ?? '[]') as string[];
      openGallery(images);
    });
  });
</script>
