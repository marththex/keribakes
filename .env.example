# Copy this file to .env and fill in real values before running locally or deploying.
# NEVER commit .env to version control.

# Resend API key — from https://resend.com/api-keys
RESEND_API_KEY=

# Owner's real inbox — kept server-side only, never exposed to the client
TO_EMAIL=

# The "from" address for outgoing emails (must be verified in Resend)
FROM_EMAIL=
